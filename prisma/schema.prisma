generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Staff {
  id                 Int                 @id @default(autoincrement())
  nome               String
  cognome            String              @default("")
  ruolo              String
  email              String?
  oreMinime          Int                 @default(0)
  oreMassime         Int                 @default(40)
  costoOra           Float               @default(0)
  listIndex          Int
  fixedShifts        String?             @default("{}")
  createdAt          DateTime            @default(now())
  moltiplicatore     Float               @default(1.0)
  postazioni         String              @default("[]")
  tenantKey          String              @default("default-tenant")
  incompatibilityId  String?
  skillLevel         String              @default("MEDIUM")
  contractType       String              @default("STANDARD")
  productivityWeight Float               @default(1.0)
  assignments        Assignment[]
  availability       Availability[]
  PermissionRequest  PermissionRequest[]
  recurringShifts    RecurringShift[]
  unavailabilities   Unavailability[]
  competencies       StaffCompetency[]

  @@unique([email, tenantKey])
  @@index([tenantKey])
}

model ShiftTemplate {
  id              Int              @id @default(autoincrement())
  nome            String
  oraInizio       String
  oraFine         String
  ruoloRichiesto  String
  giorniValidi    String           @default("")
  tenantKey       String           @default("default-tenant")
  assignments     Assignment[]
  recurringShifts RecurringShift[]

  @@index([tenantKey])
}

model Unavailability {
  id         Int     @id @default(autoincrement())
  staffId    Int
  data       String
  tipo       String
  reason     String?
  start_time String?
  end_time   String?
  tenantKey  String  @default("default-tenant")
  staff      Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantKey])
}

model Availability {
  id        Int     @id @default(autoincrement())
  staffId   Int
  dayOfWeek Int?
  date      String?
  startTime String
  endTime   String
  tenantKey String  @default("default-tenant")
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantKey])
}

model Constraint {
  id        Int    @id @default(autoincrement())
  tipo      String
  valore    String
  tenantKey String @default("default-tenant")

  @@index([tenantKey])
}

model Assignment {
  id              Int            @id @default(autoincrement())
  data            String
  staffId         Int
  shiftTemplateId Int?
  start_time      String?
  end_time        String?
  status          Boolean        @default(false)
  postazione      String?
  tenantKey       String         @default("default-tenant")
  note            String?
  shiftTemplate   ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id])
  staff           Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantKey])
}

model Budget {
  id                 Int    @id @default(autoincrement())
  data               String
  value              Float  @default(0)
  hoursLunch         Float  @default(0)
  hoursDinner        Float  @default(0)
  valueLunch         Float  @default(0)
  valueDinner        Float  @default(0)
  tenantKey          String @default("default-tenant")
  hoursDinnerHall    Float  @default(0)
  hoursDinnerKitchen Float  @default(0)
  hoursLunchHall     Float  @default(0)
  hoursLunchKitchen  Float  @default(0)
  budgetCoversDinner Int    @default(0)
  budgetCoversLunch  Int    @default(0)
  realCoversDinner   Int    @default(0)
  realCoversLunch    Int    @default(0)
  realValueDinner    Float  @default(0)
  realValueLunch     Float  @default(0)

  @@unique([data, tenantKey])
  @@index([tenantKey])
}

model CoverageRow {
  id        Int    @id @default(autoincrement())
  weekStart String
  station   String
  frequency String
  slots     String @default("{}")
  extra     String @default("{}")
  tenantKey String @default("default-tenant")

  @@index([tenantKey])
}

model ForecastRow {
  id        Int      @id @default(autoincrement())
  weekStart String
  data      String
  createdAt DateTime @default(now())
  tenantKey String   @default("default-tenant")

  @@index([tenantKey])
}

model User {
  id                Int                 @id @default(autoincrement())
  email             String              @unique
  password          String
  name              String?
  surname           String?
  dob               String?
  address           String?
  role              String              @default("OWNER")
  tenantKey         String              @default("default-tenant")
  companyName       String?
  smtpHost          String?
  smtpPassword      String?
  smtpPort          Int?
  smtpUser          String?
  createdAt         DateTime            @default(now())
  smtpProvider      String              @default("CUSTOM")
  lastLogin         DateTime?
  resetToken        String?             @unique
  resetTokenExpiry  DateTime?
  isVerified        Boolean             @default(false)
  verificationToken String?             @unique
  deviceTokens      DeviceToken[]
  loginLogs         LoginLog[]
  PermissionRequest PermissionRequest[]

  @@index([tenantKey])
}

model RecurringShift {
  id              Int            @id @default(autoincrement())
  staffId         Int
  dayOfWeek       Int
  start_time      String?
  end_time        String?
  shiftTemplateId Int?
  postazione      String?
  tenantKey       String         @default("default-tenant")
  endWeek         Int?
  startWeek       Int?
  endYear         Int?
  startYear       Int?
  shiftTemplate   ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id])
  staff           Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantKey])
}

model PermissionRequest {
  id            Int       @id @default(autoincrement())
  staffId       Int
  data          String
  tipo          String
  motivo        String?
  dettagli      String?
  status        String    @default("PENDING")
  adminResponse String?
  processedAt   DateTime?
  processedBy   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  endDate       String?
  endTime       String?
  startTime     String?
  User          User?     @relation(fields: [processedBy], references: [id])
  Staff         Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model DeviceToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    Int
  userAgent String?
  lastUsed  DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  eventType   String
  ipAddress   String?
  userAgent   String?
  isNewDevice Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Integration {
  id        Int      @id @default(autoincrement())
  tenantKey String   @default("default-tenant")
  provider  String
  apiKey    String?
  apiSecret String?
  apiUrl    String?
  status    String   @default("INACTIVE")
  config    String   @default("{}")
  updatedAt DateTime @updatedAt

  @@unique([provider, tenantKey])
  @@index([tenantKey])
}

model TrainingData {
  id        Int      @id @default(autoincrement())
  date      DateTime @default(now())
  weekStart String
  data      String
  rating    Int      @default(5)
  tenantKey String   @default("default-tenant")
  source    String   @default("MANUAL")

  @@index([tenantKey])
}

// ── Competency Rating System ─────────────────────────────────────────────────
// score: 1 = Non abilitato | 2 = In formazione | 3 = Junior OPS | 4 = Senior OPS | 5 = Senior OPS (Esperto)
model StaffCompetency {
  id         Int    @id @default(autoincrement())
  staffId    Int
  postazione String
  score      Int    @default(3)
  note       String @default("")
  tenantKey  String @default("default-tenant")
  staff      Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, postazione])
  @@index([tenantKey])
  @@index([staffId])
}

// ── Scheduling Rules Engine ───────────────────────────────────────────────────
// Each row represents one rule the auto-scheduler must respect.
// Built-in rules are seeded automatically at first API call.
// Custom rules added by managers are flagged with isBuiltin = false.
model SchedulingRule {
  id          Int      @id @default(autoincrement())
  tenantKey   String
  code        String
  name        String
  description String
  enabled     Boolean  @default(true)
  params      String   @default("{}") // JSON
  isBuiltin   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantKey, code])
  @@index([tenantKey])
}
